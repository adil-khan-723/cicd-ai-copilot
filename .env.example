# =============================================================
# DevOps AI Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# -------------------------------------------------------------
# LLM ROUTING
# Switch providers here — zero code changes needed.
# Options: ollama | anthropic
# -------------------------------------------------------------
LLM_PROVIDER=ollama
ANALYSIS_MODEL=llama3.1:8b
GENERATION_MODEL=qwen2.5-coder:14b
LLM_FALLBACK_PROVIDER=ollama

# Confidence threshold — fixes below this are diagnostic-only
CONFIDENCE_THRESHOLD=0.75

# -------------------------------------------------------------
# OLLAMA (local — start here)
# -------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=/Volumes/SSD/ollama-models
OLLAMA_TIMEOUT=120

# -------------------------------------------------------------
# ANTHROPIC (cloud — set LLM_PROVIDER=anthropic to use)
# Get your API key at https://console.anthropic.com
# Analysis model:    claude-haiku-4-5-20251001
# Generation model:  claude-sonnet-4-6
# -------------------------------------------------------------
ANTHROPIC_API_KEY=          # required when LLM_PROVIDER=anthropic
ANTHROPIC_ANALYSIS_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_GENERATION_MODEL=claude-sonnet-4-6

# -------------------------------------------------------------
# JENKINS
# -------------------------------------------------------------
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=

# -------------------------------------------------------------
# GITHUB
# -------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_DEFAULT_REPO=

# -------------------------------------------------------------
# WEBHOOK SERVER
# -------------------------------------------------------------
WEBHOOK_PORT=8000
WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0

# -------------------------------------------------------------
# CACHING
# Redis cache — leave blank to use in-memory fallback (lost on restart)
# Docker Compose sets this automatically to redis://redis:6379
# Native install: set to redis://localhost:6379 after running start.sh
# -------------------------------------------------------------
REDIS_URL=
# REDIS_PORT exposed by docker-compose (change if 6379 is taken on the host)
REDIS_PORT=6379

# -------------------------------------------------------------
# JENKINS-IN-DOCKER (used by pull_fresh_image fix to find Dockerfiles)
# Override only if your Jenkins container or workspace path differs.
# -------------------------------------------------------------
JENKINS_DOCKER_CONTAINER=jenkins
JENKINS_WORKSPACE_PATH=/var/jenkins_home/workspace

# -------------------------------------------------------------
# DATA DIRECTORY (compose only)
# Default: a named docker volume `devops_ai_data`.
# To use a host path instead, set an absolute path here (NOT ~).
# -------------------------------------------------------------
# DATA_DIR=/absolute/path/to/data

# -------------------------------------------------------------
# LOGGING
# Options: DEBUG | INFO | WARNING | ERROR
# -------------------------------------------------------------
LOG_LEVEL=INFO
AUDIT_LOG_PATH=audit.log

# Web UI
GITHUB_REPO=owner/repo      # active project repo — set via setup wizard
